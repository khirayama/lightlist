{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "react-native": ["./node_modules/react-native"],
      "react-native/*": ["./node_modules/react-native/*"],
      "@react-native/virtualized-lists": [
        "./node_modules/@react-native/virtualized-lists"
      ]
    },
    "strict": true,
    "types": ["nativewind/types"]
  }
}
