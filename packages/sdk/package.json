{
  "name": "@lightlist/sdk",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "default": "./dist/session.js"
    },
    "./settings": {
      "types": "./dist/settings.d.ts",
      "default": "./dist/settings.js"
    },
    "./taskLists": {
      "types": "./dist/taskLists.d.ts",
      "default": "./dist/taskLists.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "default": "./dist/icons.js"
    },
    "./mutations/auth": {
      "types": "./dist/mutations/auth.d.ts",
      "default": "./dist/mutations/auth.js"
    },
    "./mutations/app": {
      "types": "./dist/mutations/app.d.ts",
      "default": "./dist/mutations/app.js"
    },
    "./hooks/useOptimisticReorder": {
      "types": "./dist/hooks/useOptimisticReorder.d.ts",
      "default": "./dist/hooks/useOptimisticReorder.js"
    },
    "./utils/dateParser": {
      "types": "./dist/utils/dateParser.d.ts",
      "default": "./dist/utils/dateParser.js"
    },
    "./utils/language": {
      "types": "./dist/utils/language.d.ts",
      "default": "./dist/utils/language.js"
    },
    "./utils/errors": {
      "types": "./dist/utils/errors.d.ts",
      "default": "./dist/utils/errors.js"
    },
    "./utils/validation": {
      "types": "./dist/utils/validation.d.ts",
      "default": "./dist/utils/validation.js"
    },
    "./analytics": {
      "types": "./dist/analytics/index.d.ts",
      "react-native": "./dist/analytics/index.native.js",
      "default": "./dist/analytics/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "deploy:firestore": "firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:firestore:prod": "firebase deploy --only firestore:rules,firestore:indexes --project prod",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@firebase/auth": "^1.11.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-firebase/analytics": "^21.14.0",
    "@react-native-firebase/app": "^21.14.0",
    "@react-native-firebase/crashlytics": "^21.14.0",
    "fast-deep-equal": "^3.1.3",
    "firebase": "^12.9.0",
    "i18next": "^25.8.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@types/react": "19.2.3",
    "react": "19.1.0",
    "typescript": "^5.9.3"
  }
}
