{
  "name": "@lightlist/sdk",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./firebase": {
      "react-native": "./src/firebase/index.native.ts",
      "default": "./src/firebase/index.ts"
    },
    "./store": "./src/store.ts",
    "./types": "./src/types.ts",
    "./icons": "./src/icons.ts",
    "./mutations/auth": "./src/mutations/auth.ts",
    "./mutations/app": "./src/mutations/app.ts",
    "./hooks/useOptimisticReorder": "./src/hooks/useOptimisticReorder.ts",
    "./utils/dateParser": "./src/utils/dateParser.ts",
    "./utils/language": "./src/utils/language.ts",
    "./utils/errors": "./src/utils/errors.ts",
    "./utils/validation": "./src/utils/validation.ts",
    "./analytics": {
      "react-native": "./src/analytics/index.native.ts",
      "default": "./src/analytics/index.ts"
    }
  },
  "scripts": {
    "deploy:firestore": "firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:firestore:prod": "firebase deploy --only firestore:rules,firestore:indexes --project prod",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@firebase/auth": "^1.11.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-firebase/analytics": "^21.14.0",
    "@react-native-firebase/app": "^21.14.0",
    "@react-native-firebase/crashlytics": "^21.14.0",
    "fast-deep-equal": "^3.1.3",
    "firebase": "^12.9.0",
    "i18next": "^25.8.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@types/react": "19.2.3",
    "react": "19.1.0",
    "typescript": "^5.9.3"
  }
}
