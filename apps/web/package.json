{
  "name": "@lightlist/web",
  "version": "1.0.0",
  "packageManager": "npm@11.16.0",
  "description": "",
  "scripts": {
    "predev": "node scripts/sync-shared-locales.mjs && npm run licenses:generate",
    "prebuild": "node scripts/sync-shared-locales.mjs && npm run licenses:generate",
    "prelint": "node scripts/sync-shared-locales.mjs && npm run licenses:generate",
    "pretypecheck": "node scripts/sync-shared-locales.mjs && npm run licenses:generate",
    "licenses:generate": "node scripts/generate-licenses.mjs",
    "dev": "vite",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "knip": "knip",
    "build": "vite build",
    "preview": "vite preview",
    "cf:preview": "npm run build && wrangler pages dev dist",
    "cf:deploy": "npm run build && wrangler pages deploy dist --project-name \"$CLOUDFLARE_PAGES_PROJECT_NAME\"",
    "typecheck": "tsc --noEmit",
    "screenshots:generate": "node scripts/generate-store-screenshots.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.16",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "firebase": "^12.14.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "knip": "^6.16.1",
    "license-checker-rseidelsohn": "^5.0.1",
    "prettier": "^3.8.4",
    "sharp": "^0.35.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "wrangler": "^4.100.0"
  }
}
