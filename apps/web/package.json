{
  "name": "@lightlist/web",
  "version": "1.0.0",
  "packageManager": "npm@12.0.1",
  "engines": {
    "node": "^24.15.0 || >=26.0.0"
  },
  "description": "",
  "scripts": {
    "predev": "node scripts/sync-shared-locales.mjs && npm run licenses:generate",
    "prebuild": "node scripts/sync-shared-locales.mjs && npm run licenses:generate",
    "prelint": "node scripts/sync-shared-locales.mjs && npm run licenses:generate",
    "pretypecheck": "node scripts/sync-shared-locales.mjs && npm run licenses:generate",
    "licenses:generate": "node scripts/generate-licenses.mjs",
    "dev": "vite",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "knip": "knip",
    "build": "vite build",
    "postbuild": "node scripts/write-apple-app-site-association.mjs dist --if-configured && node scripts/write-assetlinks.mjs dist --if-configured",
    "preview": "vite preview",
    "cf:build": "npm run prebuild && vite build && node scripts/write-apple-app-site-association.mjs dist && node scripts/write-assetlinks.mjs dist",
    "cf:preview": "npm run cf:build && wrangler pages dev dist",
    "cf:deploy": "npm run cf:build && wrangler pages deploy dist --project-name \"$CLOUDFLARE_PAGES_PROJECT_NAME\"",
    "typecheck": "tsc --noEmit",
    "screenshots:generate": "node scripts/generate-store-screenshots.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "firebase": "^12.14.0",
    "i18next": "^26.3.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "knip": "^6.25.0",
    "license-checker-rseidelsohn": "^5.0.1",
    "prettier": "^3.9.4",
    "sharp": "^0.35.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "wrangler": "^4.107.1"
  }
}
